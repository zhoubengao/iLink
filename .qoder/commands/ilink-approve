#!/usr/bin/env bash
set -euo pipefail

# FR-BSH-03: ilink-approve <story> - Approve STAGING status and advance to next stage

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$DIR/_common.sh"

story_required "$@"
story="$1"
base_dir="$(story_dir "$story")"

if [[ ! -d "$base_dir" ]]; then
  log_error "Story directory not found: $base_dir"
  exit 1
fi

staging_doc=""
next_status=""
next_command=""

if [[ -f "$base_dir/${story}-review.master.md" ]]; then
  status=$(check_status "$base_dir/${story}-review.master.md")
  if [[ "$status" == "STAGING" ]]; then
    echo "QA 处于 STAGING 状态（上游根因），请人工处理："
    echo "1. 查看 review.master.md 中的 [UPSTREAM_BLOCKERS]"
    echo "2. 与 Designer 讨论修改设计，或修改需求定义"
    echo "3. 手动修改后重新执行 ilink-qa $story"
    exit 0
  fi
fi

if [[ -f "$base_dir/${story}-design.master.md" ]]; then
  status=$(check_status "$base_dir/${story}-design.master.md")
  if [[ "$status" == "STAGING" ]]; then
    staging_doc="$base_dir/${story}-design.master.md"
    next_status="PENDING_CODER"
    next_command="ilink-coder $story"
  fi
fi

if [[ -f "$base_dir/${story}-pm.master.md" ]]; then
  status=$(check_status "$base_dir/${story}-pm.master.md")
  if [[ "$status" == "STAGING" ]]; then
    staging_doc="$base_dir/${story}-pm.master.md"
    next_status="PENDING_DESIGNER"
    next_command="ilink-design $story"
  fi
fi

if [[ -z "$staging_doc" ]]; then
  log_error "No document in STAGING status found for story '$story'"
  echo ""
  echo "当前状态："
  "$DIR/ilink-status" "$story"
  exit 1
fi

log_info "Approving: $(basename "$staging_doc")"

update_status "$staging_doc" "$next_status"

log_info "Status advanced: STAGING → $next_status"
echo ""
echo "下一步: 执行 $next_command"
