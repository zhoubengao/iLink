#!/usr/bin/env bash
set -euo pipefail

# Inject Metadata (Timestamp + Hash) into a Master Doc
# Usage: ilink-inject-metadata <story> <role>
# Role: pm | design | coder | qa

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$DIR/_common.sh"

if [[ $# -lt 2 ]]; then
  echo "Usage: $0 <story> <role>" >&2
  echo "  role: pm | design | coder | qa" >&2
  exit 2
fi

story="$1"
role_input="$2"
base_dir="$(story_dir "$story")"

case "$role_input" in
  pm)
    doc="$base_dir/${story}-pm.master.md"
    meta_role="PM"
    ;;
  design)
    doc="$base_dir/${story}-design.master.md"
    meta_role="DESIGNER"
    ;;
  coder)
    doc="$base_dir/${story}-code.master.md"
    meta_role="CODER"
    ;;
  qa)
    doc="$base_dir/${story}-review.master.md"
    meta_role="QA"
    ;;
  *)
    log_error "Unknown role: $role_input (expected: pm | design | coder | qa)"
    exit 2
    ;;
esac

require_file "$doc"

# Read current status from doc (preserve what AI wrote)
current_status=$(check_status "$doc")
if [[ -z "$current_status" || "$current_status" == "MISSING" ]]; then
  log_warn "No Status found in $doc, using STAGING as default"
  current_status="STAGING"
fi

# Read target files (only relevant for coder)
target_files=""
if [[ "$role_input" == "coder" ]]; then
  target_files=$(extract_metadata "$doc" "Target_Files")
fi

inject_metadata "$doc" "$meta_role" "$current_status" "$target_files"

log_info "Metadata injected into $(basename "$doc")"
echo "  Role: $meta_role"
echo "  Status: $current_status"
echo "  Timestamp + Hash: injected"
