#!/usr/bin/env bash
set -euo pipefail

# FR-CMD-01: /ilink-pm <story> - Trigger PM Agent

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$DIR/_common.sh"

story_required "$@"
story="$1"
base_dir="$(story_dir "$story")"

req_doc="$base_dir/${story}-requirement.md"

require_file "$req_doc"

echo ""
echo "现在可以在对话中执行: /ilink-pm $story"
echo ""
echo "提示: PM 将输出 ${story}-pm.master.md，Status 将为 PENDING_DESIGNER 或 STAGING"
