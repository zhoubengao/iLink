#!/usr/bin/env bash
set -euo pipefail

# FR-CMD-03: /ilink-coder <story> - Trigger Coder Agent

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$DIR/_common.sh"

story_required "$@"
story="$1"
base_dir="$(story_dir "$story")"

design_doc="$base_dir/${story}-design.master.md"

require_file "$design_doc"

# Check status
status=$(check_status "$design_doc")
if [[ "$status" == "STAGING" ]]; then
  log_warn "Design document is in STAGING status, human review required before coding"
  echo ""
  read -p "Continue anyway? (y/N) " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    exit 1
  fi
elif [[ "$status" != "PENDING_CODER" ]]; then
  log_warn "Design document status is '$status', expected 'PENDING_CODER' or 'STAGING'"
fi

# AC-5: Detect reflux mode
if is_reflux_mode "$base_dir" "$story"; then
  log_info "Reflux mode detected: review.master.md exists with FAIL_BACK_TO_CODER"
  increment_retry_count "$base_dir"
  retry_count=$(get_retry_count "$base_dir")
  log_info "Reflux attempt: $retry_count"
fi

echo ""
echo "现在可以在对话中执行: /ilink-coder $story"
echo ""
echo "提示: Coder 将直接修改代码文件并输出 ${story}-code.master.md"
